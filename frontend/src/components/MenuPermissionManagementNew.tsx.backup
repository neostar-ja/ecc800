/**
 * Professional Menu Permission Management Component
 * ระบบจัดการสิทธิ์เมนูแบบ All-in-One - เพิ่ม ลบ แก้ไข สิทธิ์ในหน้าเดียว
 * UI สวยงาม เป็นมืออาชีพ ใช้งานง่าย
 * ออกแบบด้วย MUI + TailwindCSS
 */
import React, { useState, useEffect, useMemo } from 'react';
import {
  Box,
  Card,
  CardContent,
  Table,
  TableBody,
  TableCell,
  TableContainer,
  TableHead,
  TableRow,
  Paper,
  Button,
  IconButton,
  Alert,
  CircularProgress,
  Chip,
  Tooltip,
  Typography,
  Snackbar,
  Dialog,
  DialogTitle,
  DialogContent,
  DialogActions,
  TextField,
  Select,
  MenuItem as MuiMenuItem,
  InputLabel,
  FormControl,
  FormControlLabel,
  Switch,
  Grid,
  Divider,
  Avatar,
  Badge,
  Fade,
  alpha,
  useTheme,
  InputAdornment,
  Checkbox,
  Stack,
  ButtonGroup,
} from '@mui/material';
import {
  Refresh as RefreshIcon,
  Menu as MenuIcon,
  Visibility as ViewIcon,
  VisibilityOff as VisibilityOffIcon,
  Add as AddIcon,
  AdminPanelSettings as AdminIcon,
  SupervisorAccount as EditorIcon,
  Person as ViewerIcon,
  Save as SaveIcon,
  RestartAlt as DiscardIcon,
  Edit as EditIcon,
  Delete as DeleteIcon,
  Security as SecurityIcon,
  Settings as SettingsIcon,
  Dashboard as DashboardIcon,
  Memory as MemoryIcon,
  Analytics as AnalyticsIcon,
  Warning as WarningIcon,
  Assessment as ReportIcon,
  Business as BusinessIcon,
  ViewInAr as ViewInArIcon,
  Search as SearchIcon,
  ArrowUpward as ArrowUpIcon,
  ArrowDownward as ArrowDownIcon,
  Check as CheckIcon,
  Close as CloseIcon,
} from '@mui/icons-material';
import { useQuery, useMutation, useQueryClient } from '@tanstack/react-query';
import {
  rolesApi,
  menuItemsApi,
  permissionsApi,
  Role,
  MenuItem,
  BulkPermissionUpdate
} from '../services/authExtended';

// Icon mapping
const iconMap: { [key: string]: React.ElementType } = {
  Dashboard: DashboardIcon,
  ViewInAr: ViewInArIcon,
  Business: BusinessIcon,
  Memory: MemoryIcon,
  Analytics: AnalyticsIcon,
  Warning: WarningIcon,
  Assessment: ReportIcon,
  AdminPanelSettings: AdminIcon,
  Settings: SettingsIcon,
  Security: SecurityIcon,
  Menu: MenuIcon,
};

// Tab Panel Component
interface TabPanelProps {
  children?: React.ReactNode;
  index: number;
  value: number;
}

const TabPanel: React.FC<TabPanelProps> = ({ children, value, index }) => (
  <div role="tabpanel" hidden={value !== index} className="py-4">
    {value === index && children}
  </div>
);

// Menu Icon Selector Component
const MenuIconSelector: React.FC<{
  value: string;
  onChange: (icon: string) => void;
}> = ({ value, onChange }) => {
  const icons = Object.keys(iconMap);
  
  return (
    <FormControl fullWidth size="small">
      <InputLabel>ไอคอน</InputLabel>
      <Select
        value={value || ''}
        onChange={(e) => onChange(e.target.value)}
        label="ไอคอน"
        renderValue={(selected) => {
          const Icon = iconMap[selected] || MenuIcon;
          return (
            <Box className="flex items-center gap-2">
              <Icon fontSize="small" />
              <span>{selected}</span>
            </Box>
          );
        }}
      >
        {icons.map((iconName) => {
          const Icon = iconMap[iconName];
          return (
            <MuiMenuItem key={iconName} value={iconName}>
              <Box className="flex items-center gap-2">
                <Icon fontSize="small" />
                <span>{iconName}</span>
              </Box>
            </MuiMenuItem>
          );
        })}
      </Select>
    </FormControl>
  );
};

// Permission Cell Component สำหรับแสดงในตาราง
const PermissionCell: React.FC<{
  permission: { can_view: boolean; can_edit: boolean; can_delete: boolean };
  onChange: (field: 'can_view' | 'can_edit' | 'can_delete', value: boolean) => void;
  roleColor: 'error' | 'warning' | 'success' | 'default';
}> = ({ permission, onChange, roleColor }) => {
  const theme = useTheme();
  
  return (
    <Box 
      className="flex flex-col gap-1 p-2 rounded-lg transition-all duration-200"
      sx={{
        bgcolor: permission.can_view 
          ? alpha(theme.palette[roleColor === 'default' ? 'success' : roleColor].main, 0.1)
          : alpha(theme.palette.grey[500], 0.05),
        border: `2px solid ${
          permission.can_view 
            ? alpha(theme.palette[roleColor === 'default' ? 'success' : roleColor].main, 0.3)
            : alpha(theme.palette.grey[500], 0.1)
        }`,
        minWidth: 140,
      }}
    >
      <FormControlLabel
        control={
          <Checkbox
            checked={permission.can_view}
            onChange={(e) => onChange('can_view', e.target.checked)}
            size="small"
            color={roleColor === 'default' ? 'success' : roleColor}
          />
        }
        label={
          <Typography variant="caption" fontWeight="bold">
            ดูได้
          </Typography>
        }
        sx={{ m: 0 }}
      />
      {permission.can_view && (
        <Fade in={permission.can_view}>
          <Box className="pl-2 flex flex-col gap-1">
            <FormControlLabel
              control={
                <Checkbox
                  checked={permission.can_edit}
                  onChange={(e) => onChange('can_edit', e.target.checked)}
                  size="small"
                  color="warning"
                />
              }
              label={<Typography variant="caption">แก้ไข</Typography>}
              sx={{ m: 0 }}
            />
            <FormControlLabel
              control={
                <Checkbox
                  checked={permission.can_delete}
                  onChange={(e) => onChange('can_delete', e.target.checked)}
                  size="small"
                  color="error"
                />
              }
              label={<Typography variant="caption">ลบ</Typography>}
              sx={{ m: 0 }}
            />
          </Box>
        </Fade>
      )}
    </Box>
  );
};

// Main Component
const MenuPermissionManagementNew: React.FC = () => {
  const theme = useTheme();
  const queryClient = useQueryClient();
  const [activeTab, setActiveTab] = useState(0);
  const [searchTerm, setSearchTerm] = useState('');
  const [snackbar, setSnackbar] = useState<{ open: boolean; message: string; severity: 'success' | 'error' | 'info' }>({
    open: false,
    message: '',
    severity: 'success'
  });

  // Menu Dialog States
  const [menuDialogOpen, setMenuDialogOpen] = useState(false);
  const [editingMenu, setEditingMenu] = useState<MenuItem | null>(null);
  const [deleteConfirmOpen, setDeleteConfirmOpen] = useState(false);
  const [menuToDelete, setMenuToDelete] = useState<MenuItem | null>(null);
  const [menuFormData, setMenuFormData] = useState({
    name: '',
    display_name: '',
    path: '',
    icon: 'Menu',
    parent_id: undefined as number | undefined,
    order: 1,
    is_visible: true,
    description: ''
  });

  // Permission States
  const [localPermissions, setLocalPermissions] = useState<{
    [roleId: number]: { [menuId: number]: { can_view: boolean; can_edit: boolean; can_delete: boolean } }
  }>({});
  const [hasPermissionChanges, setHasPermissionChanges] = useState(false);

  // Fetch Data
  const { data: rolesData, isLoading: rolesLoading } = useQuery({
    queryKey: ['roles'],
    queryFn: () => rolesApi.list({ is_active: true })
  });
  const roles = Array.isArray(rolesData) ? rolesData : [];

  const { data: menuItemsData, isLoading: menusLoading, refetch: refetchMenus } = useQuery({
    queryKey: ['menuItems'],
    queryFn: () => menuItemsApi.listAll()
  });
  const menuItems = Array.isArray(menuItemsData) ? menuItemsData : [];

  const { data: permissionMatrixData, isLoading: permissionsLoading, refetch: refetchPermissions } = useQuery({
    queryKey: ['permissionMatrix'],
    queryFn: () => permissionsApi.getMatrix()
  });
  const permissionMatrix = Array.isArray(permissionMatrixData) ? permissionMatrixData : [];

  // Initialize local permissions
  useEffect(() => {
    if (permissionMatrix.length > 0) {
      const newLocalPermissions: typeof localPermissions = {};
      permissionMatrix.forEach((roleMatrix) => {
        newLocalPermissions[roleMatrix.role_id] = {};
        roleMatrix.permissions.forEach((perm) => {
          newLocalPermissions[roleMatrix.role_id][perm.menu_item_id] = {
            can_view: perm.can_view,
            can_edit: perm.can_edit,
            can_delete: perm.can_delete
          };
        });
      });
      setLocalPermissions(newLocalPermissions);
      setHasPermissionChanges(false);
    }
  }, [permissionMatrix]);

  // Filtered menu items
  const filteredMenuItems = useMemo(() => {
    if (!searchTerm) return menuItems;
    const term = searchTerm.toLowerCase();
    return menuItems.filter(m => 
      m.name.toLowerCase().includes(term) ||
      m.display_name.toLowerCase().includes(term) ||
      m.path.toLowerCase().includes(term)
    );
  }, [menuItems, searchTerm]);

  // Mutations
  const createMenuMutation = useMutation({
    mutationFn: (data: typeof menuFormData) => menuItemsApi.create(data),
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ['menuItems'] });
      queryClient.invalidateQueries({ queryKey: ['permissionMatrix'] });
      setSnackbar({ open: true, message: 'สร้างเมนูสำเร็จ', severity: 'success' });
      handleCloseMenuDialog();
    },
    onError: (error: any) => {
      setSnackbar({ open: true, message: error?.response?.data?.detail || 'เกิดข้อผิดพลาด', severity: 'error' });
    }
  });

  const updateMenuMutation = useMutation({
    mutationFn: ({ id, data }: { id: number; data: Partial<typeof menuFormData> }) => 
      menuItemsApi.update(id, data),
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ['menuItems'] });
      setSnackbar({ open: true, message: 'แก้ไขเมนูสำเร็จ', severity: 'success' });
      handleCloseMenuDialog();
    },
    onError: (error: any) => {
      setSnackbar({ open: true, message: error?.response?.data?.detail || 'เกิดข้อผิดพลาด', severity: 'error' });
    }
  });

  const deleteMenuMutation = useMutation({
    mutationFn: (id: number) => menuItemsApi.delete(id),
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ['menuItems'] });
      queryClient.invalidateQueries({ queryKey: ['permissionMatrix'] });
      setSnackbar({ open: true, message: 'ลบเมนูสำเร็จ', severity: 'success' });
      setDeleteConfirmOpen(false);
      setMenuToDelete(null);
    },
    onError: (error: any) => {
      setSnackbar({ open: true, message: error?.response?.data?.detail || 'เกิดข้อผิดพลาด', severity: 'error' });
    }
  });

  const bulkUpdatePermissionMutation = useMutation({
    mutationFn: (data: BulkPermissionUpdate) => permissionsApi.bulkUpdate(data),
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ['permissionMatrix'] });
      queryClient.invalidateQueries({ queryKey: ['currentUserPermissions'] });
    }
  });

  const initDefaultsMutation = useMutation({
    mutationFn: async () => {
      await menuItemsApi.initDefaults();
      await permissionsApi.initDefaults();
    },
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ['menuItems'] });
      queryClient.invalidateQueries({ queryKey: ['permissionMatrix'] });
      setSnackbar({ open: true, message: 'สร้างข้อมูลเริ่มต้นสำเร็จ', severity: 'success' });
    }

  // Handlers
  const handleOpenMenuDialog = (menu?: MenuItem) => {
    if (menu) {
      setEditingMenu(menu);
      setMenuFormData({
        name: menu.name,
        display_name: menu.display_name,
        path: menu.path,
        icon: menu.icon || 'Menu',
        parent_id: menu.parent_id || undefined,
        order: menu.order,
        is_visible: menu.is_visible,
        description: menu.description || ''
      });
    } else {
      setEditingMenu(null);
      setMenuFormData({
        name: '',
        display_name: '',
        path: '',
        icon: 'Menu',
        parent_id: undefined,
        order: menuItems.length + 1,
        is_visible: true,
        description: ''
      });
    }
    setMenuDialogOpen(true);
  };

  const handleCloseMenuDialog = () => {
    setMenuDialogOpen(false);
    setEditingMenu(null);
  };

  const handleSubmitMenu = () => {
    if (editingMenu) {
      updateMenuMutation.mutate({ id: editingMenu.id, data: menuFormData });
    } else {
      createMenuMutation.mutate(menuFormData);
    }
  };

  const handleDeleteMenu = (menu: MenuItem) => {
    setMenuToDelete(menu);
    setDeleteConfirmOpen(true);
  };

  const handleConfirmDelete = () => {
    if (menuToDelete) {
      deleteMenuMutation.mutate(menuToDelete.id);
    }
  };

  const handlePermissionChange = (roleId: number, menuId: number, field: 'can_view' | 'can_edit' | 'can_delete', value: boolean) => {
    setLocalPermissions(prev => {
      const newPerms = { ...prev };
      if (!newPerms[roleId]) newPerms[roleId] = {};
      if (!newPerms[roleId][menuId]) {
        newPerms[roleId][menuId] = { can_view: false, can_edit: false, can_delete: false };
      }
      
      newPerms[roleId][menuId][field] = value;
      
      // If can_view is false, reset can_edit and can_delete
      if (field === 'can_view' && !value) {
        newPerms[roleId][menuId].can_edit = false;
        newPerms[roleId][menuId].can_delete = false;
      }
      
      // If can_edit or can_delete is true, ensure can_view is true
      if ((field === 'can_edit' || field === 'can_delete') && value) {
        newPerms[roleId][menuId].can_view = true;
      }
      
      return newPerms;
    });
    setHasPermissionChanges(true);
  };

  const handleSelectAllForRole = (roleId: number, value: boolean) => {
    setLocalPermissions(prev => {
      const newPerms = { ...prev };
      if (!newPerms[roleId]) newPerms[roleId] = {};
      
      menuItems.forEach(menu => {
        newPerms[roleId][menu.id] = {
          can_view: value,
          can_edit: false,
          can_delete: false
        };
      });
      
      return newPerms;
    });
    setHasPermissionChanges(true);
  };

  const handleSaveAllPermissions = async () => {
    try {
      const updates: Promise<any>[] = [];
      
      for (const roleId in localPermissions) {
        const permissions = Object.entries(localPermissions[parseInt(roleId)]).map(([menuId, perms]) => ({
          menu_item_id: parseInt(menuId),
          can_view: perms.can_view,
          can_edit: perms.can_edit,
          can_delete: perms.can_delete
        }));

        updates.push(
          bulkUpdatePermissionMutation.mutateAsync({
            role_id: parseInt(roleId),
            permissions
          })
        );
      }

      await Promise.all(updates);
      setHasPermissionChanges(false);
      setSnackbar({ open: true, message: 'บันทึกสิทธิ์ทั้งหมดสำเร็จ', severity: 'success' });
    } catch (error) {
      setSnackbar({ open: true, message: 'เกิดข้อผิดพลาดในการบันทึก', severity: 'error' });
    }
  };

  const handleDiscardChanges = () => {
    // Re-initialize from server data
    const newLocalPermissions: typeof localPermissions = {};
    permissionMatrix.forEach((roleMatrix) => {
      newLocalPermissions[roleMatrix.role_id] = {};
      roleMatrix.permissions.forEach((perm) => {
        newLocalPermissions[roleMatrix.role_id][perm.menu_item_id] = {
          can_view: perm.can_view,
          can_edit: perm.can_edit,
          can_delete: perm.can_delete
        };
      });
    });
    setLocalPermissions(newLocalPermissions);
    setHasPermissionChanges(false);
    setSnackbar({ open: true, message: 'ยกเลิกการเปลี่ยนแปลง', severity: 'info' });
  };

  const handleMoveMenu = (menu: MenuItem, direction: 'up' | 'down') => {
    const currentIndex = menuItems.findIndex(m => m.id === menu.id);
    const newOrder = direction === 'up' ? menu.order - 1 : menu.order + 1;
    
    if (newOrder < 1 || newOrder > menuItems.length) return;
    
    updateMenuMutation.mutate({
      id: menu.id,
      data: { order: newOrder }
    });
  };

  const getRoleColor = (roleName: string): 'error' | 'warning' | 'success' | 'default' => {
    switch (roleName.toLowerCase()) {
      case 'admin': return 'error';
      case 'editor': return 'warning';
      case 'viewer': return 'success';
      default: return 'default';
    }
  };

  const getRoleIcon = (roleName: string) => {
    switch (roleName.toLowerCase()) {
      case 'admin': return <AdminIcon />;
      case 'editor': return <EditorIcon />;
      default: return <ViewerIcon />;
    }
  };

  const isLoading = rolesLoading || menusLoading || permissionsLoading;

  return (
    <Box className="p-4">
      {/* Header */}
      <Box className="mb-6">
        <Box className="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-4">
          <Box>
            <Typography variant="h4" fontWeight="bold" className="flex items-center gap-3 mb-2">
              <Avatar 
                sx={{ 
                  bgcolor: alpha(theme.palette.primary.main, 0.1),
                  color: theme.palette.primary.main,
                  width: 48,
                  height: 48
                }}
              >
                <SecurityIcon />
              </Avatar>
              จัดการสิทธิ์และเมนู
            </Typography>
            <Typography variant="body1" color="text.secondary" className="ml-16">
              กำหนดสิทธิ์การเข้าถึงและจัดการเมนูในหน้าเดียว - ใช้งานง่าย สะดวก รวดเร็ว
            </Typography>
          </Box>
          
          <Stack direction="row" spacing={2}>
            {hasPermissionChanges && (
              <Fade in={hasPermissionChanges}>
                <ButtonGroup variant="contained" size="large">
                  <Button
                    color="warning"
                    startIcon={<DiscardIcon />}
                    onClick={handleDiscardChanges}
                  >
                    ยกเลิก
                  </Button>
                  <Button
                    color="success"
                    startIcon={<SaveIcon />}
                    onClick={handleSaveAllPermissions}
                    disabled={bulkUpdatePermissionMutation.isPending}
                  >
                    {bulkUpdatePermissionMutation.isPending ? (
                      <CircularProgress size={20} color="inherit" />
                    ) : (
                      'บันทึกทั้งหมด'
                    )}
                  </Button>
                </ButtonGroup>
              </Fade>
            )}
            <Tooltip title="รีเฟรชข้อมูล">
              <IconButton 
                onClick={() => {
                  refetchMenus();
                  refetchPermissions();
                }}
                disabled={isLoading}
                size="large"
                sx={{
                  border: `2px solid ${alpha(theme.palette.primary.main, 0.2)}`,
                }}
              >
                <RefreshIcon className={isLoading ? 'animate-spin' : ''} />
              </IconButton>
            </Tooltip>
          </Stack>
        </Box>

        {hasPermissionChanges && (
          <Fade in={hasPermissionChanges}>
            <Alert 
              severity="warning" 
              className="mb-4"
              sx={{ 
                borderRadius: 2,
                border: `2px solid ${alpha(theme.palette.warning.main, 0.3)}`,
              }}
              icon={<SaveIcon fontSize="inherit" />}
            >
              <Typography variant="subtitle2" fontWeight="bold">
                มีการเปลี่ยนแปลงที่ยังไม่ได้บันทึก
              </Typography>
              <Typography variant="body2">
                กรุณาคลิก "บันทึกทั้งหมด" เพื่อบันทึกการเปลี่ยนแปลง หรือ "ยกเลิก" เพื่อยกเลิก
              </Typography>
            </Alert>
          </Fade>
        )}

        {/* Top Actions */}
        <Card 
          elevation={0}
          sx={{
            background: `linear-gradient(135deg, ${alpha(theme.palette.primary.main, 0.05)} 0%, ${alpha(theme.palette.secondary.main, 0.05)} 100%)`,
            border: `2px solid ${alpha(theme.palette.primary.main, 0.1)}`,
            borderRadius: 3,
            mb: 3,
          }}
        >
          <CardContent>
            <Grid container spacing={2} alignItems="center">
              <Grid item xs={12} md={6}>
                <TextField
                  fullWidth
                  placeholder="ค้นหาเมนูด้วยชื่อ, Display Name หรือ Path..."
                  size="medium"
                  value={searchTerm}
                  onChange={(e) => setSearchTerm(e.target.value)}
                  InputProps={{
                    startAdornment: (
                      <InputAdornment position="start">
                        <SearchIcon />
                      </InputAdornment>
                    ),
                  }}
                  sx={{
                    '& .MuiOutlinedInput-root': {
                      bgcolor: 'background.paper',
                    }
                  }}
                />
              </Grid>
              <Grid item xs={12} md={6}>
                <Stack direction="row" spacing={2} justifyContent="flex-end">
                  <Button
                    variant="outlined"
                    size="large"
                    onClick={() => initDefaultsMutation.mutate()}
                    disabled={initDefaultsMutation.isPending}
                  >
                    {initDefaultsMutation.isPending ? (
                      <CircularProgress size={20} />
                    ) : (
                      'สร้างข้อมูลเริ่มต้น'
                    )}
                  </Button>
                  <Button
                    variant="contained"
                    size="large"
                    startIcon={<AddIcon />}
                    onClick={() => handleOpenMenuDialog()}
                  >
                    เพิ่มเมนูใหม่
                  </Button>
                </Stack>
              </Grid>
            </Grid>
          </CardContent>
        </Card>
      </Box>

      {/* Main Content: Permission Matrix */}
      {isLoading ? (
        <Box className="flex justify-center items-center py-20">
          <Box textAlign="center">
            <CircularProgress size={60} thickness={4} />
            <Typography variant="h6" color="text.secondary" mt={2}>
              กำลังโหลดข้อมูล...
            </Typography>
          </Box>
        </Box>
      ) : menuItems.length === 0 ? (
        <Alert 
          severity="info"
          sx={{ borderRadius: 3 }}
          action={
            <Button 
              color="inherit" 
              size="small"
              onClick={() => initDefaultsMutation.mutate()}
              disabled={initDefaultsMutation.isPending}
            >
              สร้างข้อมูลเริ่มต้น
            </Button>
          }
        >
          <Typography variant="subtitle2" fontWeight="bold">
            ไม่มีข้อมูลเมนูในระบบ
          </Typography>
          <Typography variant="body2">
            คลิก "สร้างข้อมูลเริ่มต้น" เพื่อเริ่มต้นใช้งานระบบ
          </Typography>
        </Alert>
      ) : (
        <Card 
          elevation={0}
          sx={{
            border: `2px solid ${alpha(theme.palette.divider, 0.1)}`,
            borderRadius: 3,
            overflow: 'hidden',
          }}
        >
          <TableContainer>
            <Table stickyHeader>
              <TableHead>
                <TableRow>
                  <TableCell 
                    sx={{ 
                      bgcolor: alpha(theme.palette.primary.main, 0.1),
                      fontWeight: 'bold',
                      fontSize: '1rem',
                      borderRight: `2px solid ${alpha(theme.palette.divider, 0.2)}`,
                      minWidth: 280,
                    }}
                  >
                    <Box className="flex items-center gap-2">
                      <MenuIcon />
                      เมนู
                    </Box>
                  </TableCell>
                  {roles.map((role) => (
                    <TableCell 
                      key={role.id}
                      align="center"
                      sx={{ 
                        bgcolor: alpha(theme.palette[getRoleColor(role.name)].main, 0.1),
                        fontWeight: 'bold',
                        fontSize: '1rem',
                        minWidth: 160,
                      }}
                    >
                      <Box className="flex flex-col items-center gap-1">
                        <Avatar
                          sx={{
                            bgcolor: alpha(theme.palette[getRoleColor(role.name)].main, 0.2),
                            color: theme.palette[getRoleColor(role.name)].main,
                          }}
                        >
                          {getRoleIcon(role.name)}
                        </Avatar>
                        <Typography variant="subtitle2" fontWeight="bold">
                          {role.display_name}
                        </Typography>
                        <Chip 
                          label={`Level ${role.level}`}
                          size="small"
                          color={getRoleColor(role.name)}
                        />
                      </Box>
                    </TableCell>
                  ))}
                  <TableCell
                    align="center"
                    sx={{
                      bgcolor: alpha(theme.palette.grey[500], 0.1),
                      fontWeight: 'bold',
                      fontSize: '1rem',
                      width: 160,
                    }}
                  >
                    จัดการ
                  </TableCell>
                </TableRow>
              </TableHead>
              <TableBody>
                {filteredMenuItems.map((menu, index) => {
                  const MenuIconComponent = iconMap[menu.icon || 'Menu'] || MenuIcon;
                  
                  return (
                    <TableRow 
                      key={menu.id}
                      hover
                      sx={{
                        '&:hover': {
                          bgcolor: alpha(theme.palette.primary.main, 0.02),
                        }
                      }}
                    >
                      <TableCell
                        sx={{
                          borderRight: `2px solid ${alpha(theme.palette.divider, 0.1)}`,
                        }}
                      >
                        <Box className="flex items-center justify-between">
                          <Box className="flex items-center gap-3">
                            <Box className="flex flex-col">
                              <IconButton
                                size="small"
                                onClick={() => handleMoveMenu(menu, 'up')}
                                disabled={index === 0}
                              >
                                <ArrowUpIcon fontSize="small" />
                              </IconButton>
                              <Typography 
                                variant="caption" 
                                fontWeight="bold"
                                className="text-center"
                                sx={{ color: 'text.secondary' }}
                              >
                                {menu.order}
                              </Typography>
                              <IconButton
                                size="small"
                                onClick={() => handleMoveMenu(menu, 'down')}
                                disabled={index === menuItems.length - 1}
                              >
                                <ArrowDownIcon fontSize="small" />
                              </IconButton>
                            </Box>
                            <Avatar
                              sx={{
                                width: 44,
                                height: 44,
                                bgcolor: alpha(theme.palette.primary.main, 0.1),
                                color: theme.palette.primary.main,
                              }}
                            >
                              <MenuIconComponent />
                            </Avatar>
                            <Box>
                              <Typography variant="subtitle1" fontWeight="bold">
                                {menu.display_name}
                              </Typography>
                              <Typography variant="caption" color="text.secondary" className="font-mono">
                                {menu.path}
                              </Typography>
                              <Box mt={0.5}>
                                <Chip
                                  icon={menu.is_visible ? <ViewIcon /> : <VisibilityOffIcon />}
                                  label={menu.is_visible ? 'แสดง' : 'ซ่อน'}
                                  size="small"
                                  color={menu.is_visible ? 'success' : 'default'}
                                  variant="outlined"
                                />
                              </Box>
                            </Box>
                          </Box>
                        </Box>
                      </TableCell>
                      {roles.map((role) => {
                        const perm = localPermissions[role.id]?.[menu.id] || {
                          can_view: false,
                          can_edit: false,
                          can_delete: false,
                        };
                        
                        return (
                          <TableCell key={role.id} align="center">
                            <PermissionCell
                              permission={perm}
                              onChange={(field, value) =>
                                handlePermissionChange(role.id, menu.id, field, value)
                              }
                              roleColor={getRoleColor(role.name)}
                            />
                          </TableCell>
                        );
                      })}
                      <TableCell align="center">
                        <Stack direction="column" spacing={1} alignItems="center">
                          <Button
                            variant="outlined"
                            size="small"
                            startIcon={<EditIcon />}
                            onClick={() => handleOpenMenuDialog(menu)}
                            fullWidth
                          >
                            แก้ไข
                          </Button>
                          <Button
                            variant="outlined"
                            size="small"
                            color="error"
                            startIcon={<DeleteIcon />}
                            onClick={() => handleDeleteMenu(menu)}
                            fullWidth
                          >
                            ลบ
                          </Button>
                        </Stack>
                      </TableCell>
                    </TableRow>
                  );
                })}
              </TableBody>
            </Table>
          </TableContainer>
        </Card>
      )}           <IconButton 
                              size="small" 
                              color="error"
                              onClick={() => handleDeleteMenu(menu)}
                            >
                              <DeleteIcon fontSize="small" />
                            </IconButton>
                          </Tooltip>
                        </Box>
                      </TableCell>
                    </TableRow>
                  );
                })}
              </TableBody>
            </Table>
          </TableContainer>
        )}
      </TabPanel>

      {/* Menu Dialog */}
      <Dialog
        open={menuDialogOpen}
        onClose={handleCloseMenuDialog}
        maxWidth="sm"
        fullWidth
        PaperProps={{
          sx: { borderRadius: 3 }
        }}
      >
        <DialogTitle className="flex items-center gap-2">
          {editingMenu ? <EditIcon color="primary" /> : <AddIcon color="primary" />}
          {editingMenu ? 'แก้ไขเมนู' : 'เพิ่มเมนูใหม่'}
        </DialogTitle>
        <DialogContent dividers>
          <Grid container spacing={3} className="pt-2">
            <Grid item xs={12} sm={6}>
              <TextField
                label="ชื่อเมนู (name)"
                value={menuFormData.name}
                onChange={(e) => setMenuFormData({ ...menuFormData, name: e.target.value })}
                fullWidth
                required
                helperText="ชื่อภาษาอังกฤษ เช่น dashboard"
                disabled={!!editingMenu}
              />
            </Grid>
            <Grid item xs={12} sm={6}>
              <TextField
                label="ชื่อแสดง (display_name)"
                value={menuFormData.display_name}
                onChange={(e) => setMenuFormData({ ...menuFormData, display_name: e.target.value })}
                fullWidth
                required
                helperText="ชื่อที่แสดงในเมนู"
              />
            </Grid>
            <Grid item xs={12} sm={6}>
              <TextField
                label="Path"
                value={menuFormData.path}
                onChange={(e) => setMenuFormData({ ...menuFormData, path: e.target.value })}
                fullWidth
                required
                helperText="เช่น /dashboard"
              />
            </Grid>
            <Grid item xs={12} sm={6}>
              <MenuIconSelector
                value={menuFormData.icon || ''}
                onChange={(icon) => setMenuFormData({ ...menuFormData, icon })}
              />
            </Grid>
            <Grid item xs={12} sm={6}>
              <TextField
                label="ลำดับ"
                type="number"
                value={menuFormData.order}
                onChange={(e) => setMenuFormData({ ...menuFormData, order: parseInt(e.target.value) || 1 })}
                fullWidth
                inputProps={{ min: 1 }}
              />
            </Grid>
            <Grid item xs={12} sm={6}>
              <FormControlLabel
                control={
                  <Switch
                    checked={menuFormData.is_visible}
                    onChange={(e) => setMenuFormData({ ...menuFormData, is_visible: e.target.checked })}
                    color="success"
                  />
                }
                label={menuFormData.is_visible ? 'แสดงเมนู' : 'ซ่อนเมนู'}
              />
            </Grid>
            <Grid item xs={12}>
              <TextField
                label="คำอธิบาย"
                value={menuFormData.description}
                onChange={(e) => setMenuFormData({ ...menuFormData, description: e.target.value })}
                fullWidth
                multiline
                rows={2}
              />
            </Grid>
          </Grid>
        </DialogContent>
        <DialogActions className="p-4">
          <Button onClick={handleCloseMenuDialog} color="inherit">
            ยกเลิก
          </Button>
          <Button
            variant="contained"
            onClick={handleSubmitMenu}
            disabled={
              !menuFormData.name ||
              !menuFormData.display_name ||
              !menuFormData.path ||
              createMenuMutation.isPending ||
              updateMenuMutation.isPending
            }
            startIcon={editingMenu ? <SaveIcon /> : <AddIcon />}
          >
            {(createMenuMutation.isPending || updateMenuMutation.isPending) ? (
              <CircularProgress size={20} />
            ) : (
              editingMenu ? 'บันทึก' : 'เพิ่มเมนู'
            )}
          </Button>
        </DialogActions>
      </Dialog>

      {/* Delete Confirmation Dialog */}
      <Dialog
        open={deleteConfirmOpen}
        onClose={() => setDeleteConfirmOpen(false)}
        PaperProps={{
          sx: { borderRadius: 3 }
        }}
      >
        <DialogTitle className="flex items-center gap-2 text-red-600">
          <DeleteIcon />
          ยืนยันการลบเมนู
        </DialogTitle>
        <DialogContent>
          <Typography>
            คุณต้องการลบเมนู <strong>"{menuToDelete?.display_name}"</strong> ใช่หรือไม่?
          </Typography>
          <Typography variant="body2" color="text.secondary" className="mt-2">
            การลบเมนูจะลบสิทธิ์ที่เกี่ยวข้องทั้งหมดด้วย และไม่สามารถกู้คืนได้
          </Typography>
        </DialogContent>
        <DialogActions className="p-4">
          <Button onClick={() => setDeleteConfirmOpen(false)} color="inherit">
            ยกเลิก
          </Button>
          <Button
            variant="contained"
            color="error"
            onClick={handleConfirmDelete}
            disabled={deleteMenuMutation.isPending}
            startIcon={deleteMenuMutation.isPending ? <CircularProgress size={16} /> : <DeleteIcon />}
          >
            ลบเมนู
          </Button>
        </DialogActions>
      </Dialog>

      {/* Snackbar */}
      <Snackbar
        open={snackbar.open}
        autoHideDuration={4000}
        onClose={() => setSnackbar({ ...snackbar, open: false })}
        anchorOrigin={{ vertical: 'bottom', horizontal: 'right' }}
      >
        <Alert
          onClose={() => setSnackbar({ ...snackbar, open: false })}
          severity={snackbar.severity}
          variant="filled"
          className="shadow-lg"
        >
          {snackbar.message}
        </Alert>
      </Snackbar>
    </Box>
  );
};

export default MenuPermissionManagementNew;
